# =============================================
# PAPPI ATENDENTE — PRODUÇÃO PRIVADA
# Copie para .env e preencha os valores reais.
# NUNCA commite o .env com dados reais.
# =============================================

NODE_ENV=production
PORT=10000

# OBRIGATÓRIO: Prod e staging não compartilham sessão (evita 440)
APP_ENV=prod

# OBRIGATÓRIO: Baileys exige 1 único processo
WEB_CONCURRENCY=1

# ── Separação de processos (recomendado em produção) ──
# Web: start:web → RUN_BAILEYS=false, RUN_JOBS=true
# Baileys: start:baileys → RUN_BAILEYS=true, RUN_JOBS=false
# Monólito: index.js → RUN_JOBS=true, RUN_BAILEYS=true

RUN_JOBS=true
RUN_BAILEYS=true
BAILEYS_ENABLED=true

# Baileys 440 (ver docs/BAILEYS_440.md)
BAILEYS_LOCK_TTL_MS=60000
# BAILEYS_CLEAR_AUTH_ON_440=true — apenas se 440 persiste sem causa aparente

# ── Banco (Supabase / Postgres) ──
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# ── Segurança interna ──
ATTENDANT_API_KEY="chave_forte_producao"
ADMIN_API_KEY="chave_admin_forte"
WEBHOOK_VERIFY_TOKEN="token_webhook_meta"

# Auth corporativa
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET="pappi-media"
USE_STAFF_AUTH=true
ALLOW_API_KEY_FALLBACK=false

# URLs (domínio privado da empresa)
APP_URL="https://app.pappiatendente.com.br"
API_URL="https://api.pappiatendente.com.br"
CORS_ORIGIN="https://app.pappiatendente.com.br"

# ── WhatsApp / Meta ──
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WABA_ID=""

# ── Cardápio Web ──
CARDAPIOWEB_BASE_URL="https://integracao.cardapioweb.com"
CARDAPIOWEB_API_KEY=""
CARDAPIOWEB_PARTNER_KEY=""
CARDAPIOWEB_STORE_ID=""

# ── IA ──
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
# OPENAI_API_KEY=""  # fallback opcional
# GROQ_API_KEY=""    # fallback opcional

# ── Google Maps ──
GOOGLE_MAPS_API_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Loja ──
STORE_LAT=-22.9060
STORE_LNG=-47.0616

# ── Observabilidade ──
LOG_LEVEL=info
# HEALTHCHECK_TOKEN="token_secreto_health"
# SENTRY_DSN=""  # opcional
# REDIS_URL=""   # opcional, para rate limit distribuído

# ── Opcionais ──
# INSTAGRAM_PAGE_ID=""
# FACEBOOK_PAGE_ID=""
# FACEBOOK_PAGE_TOKEN=""
# SKIP_HOURS_CHECK=false
# CONVERSATION_HANDOFF_TIMEOUT_MIN=15
META_APP_SECRET=
METRICS_TOKEN=
ENTERPRISE_MODE=true
