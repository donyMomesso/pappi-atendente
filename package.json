{
  "name": "pappi-atendente",
  "version": "3.2.0-enterprise",
  "description": "Pappi Atendente Enterprise — web, socket, jobs, Baileys, observabilidade, idempotência e base para filas Redis/BullMQ.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:web": "node src/bootstrap/http.js",
    "start:jobs": "node src/bootstrap/jobs.js",
    "start:baileys": "node src/bootstrap/baileys.js",
    "dev": "npx nodemon --ext js,env --delay 2 --exec node index.js",
    "healthcheck": "node -e \"require('http').get(process.env.HEALTH_URL||'http://localhost:10000/health',r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))\"",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:migrate:new": "prisma migrate dev --name",
    "db:seed": "node prisma/seed.js",
    "create-admin": "node scripts/create-first-admin.js",
    "lint": "eslint . --ext .js --ignore-path .gitignore",
    "lint:fix": "eslint . --ext .js --ignore-path .gitignore --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"*.js\"",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "start:worker": "node src/bootstrap/worker.js",
    "test:smoke": "node scripts/smoke-enterprise.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^5.10.0",
    "@supabase/supabase-js": "^2.99.2",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.7.0",
    "bullmq": "^5.71.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "node-fetch": "^2.7.0",
    "pino": "^9.6.0",
    "postgres": "^3.4.8",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.8.1",
    "prisma": "^5.10.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/services/baileys*.js",
      "!src/services/socket.service.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
