# =============================================
# BANCO DE DADOS INTERNO (Supabase / Neon / Railway)
# =============================================
DATABASE_URL="postgresql://usuario:senha@host:5432/nomebanco?sslmode=require"
DIRECT_URL="postgresql://usuario:senha@host:5432/nomebanco?sslmode=require"

# =============================================
# SEGURANÇA
# =============================================
# Chave para o painel de atendimento
ATTENDANT_API_KEY="chave_secreta_atendente"
# Chave para rotas de admin (gerenciar tenants)
ADMIN_API_KEY="chave_secreta_admin"

# =============================================
# WEBHOOK META (verificação inicial)
# =============================================
WEBHOOK_VERIFY_TOKEN="token_secreto_que_voce_escolhe"

# =============================================
# FALLBACK SINGLE-TENANT (opcional)
# Se você tem apenas uma loja, pode configurar aqui.
# Em multi-tenant, os dados ficam no banco (tabela tenants).
# =============================================
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WABA_ID=""

CARDAPIOWEB_BASE_URL="https://integracao.cardapioweb.com"
CARDAPIOWEB_API_KEY=""
CARDAPIOWEB_PARTNER_KEY=""
CARDAPIOWEB_STORE_ID=""

# =============================================
# GOOGLE MAPS (cálculo de distância/taxa)
# =============================================
GOOGLE_MAPS_API_KEY=""

# =============================================
# GEMINI (IA)
# =============================================
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# =============================================
# BANCO INTER (PIX — opcional)
# =============================================
# INTER_CLIENT_ID=""
# INTER_CLIENT_SECRET=""
# INTER_CHAVE_PIX=""
# INTER_CONTA_CORRENTE=""
# INTER_CERT_PATH="./certificados/inter.crt"
# INTER_KEY_PATH="./certificados/inter.key"

# =============================================
# COORDENADAS DA LOJA (fallback)
# =============================================
# STORE_LAT=-22.9060
# STORE_LNG=-47.0616

# =============================================
# SERVIDOR
# =============================================
PORT=10000
NODE_ENV=production
