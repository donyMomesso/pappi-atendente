# =============================================
# BANCO DE DADOS INTERNO (Supabase / Neon / Railway)
# =============================================
DATABASE_URL="postgresql://usuario:senha@host:5432/nomebanco?sslmode=require"
DIRECT_URL="postgresql://usuario:senha@host:5432/nomebanco?sslmode=require"

# =============================================
# SEGURANГ‡A
# =============================================
ATTENDANT_API_KEY="chave_secreta_atendente"
ADMIN_API_KEY="chave_secreta_admin"

# Auth corporativa (Supabase) вЂ” painel fechado
# NUNCA expor SUPABASE_SERVICE_ROLE_KEY no frontend.
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
USE_STAFF_AUTH=true
# ALLOW_API_KEY_FALLBACK=true вЂ” aceita API key quando sessГЈo invГЎlida (integraГ§Гµes tГ©cnicas)
ALLOW_API_KEY_FALLBACK=false
APP_URL="https://app.pappiatendente.com.br"
API_URL="https://api.pappiatendente.com.br"
# CORS: domГ­nio do app, ou * para aceitar qualquer origem (ex: acesso de outro PC/IP)
CORS_ORIGIN="https://app.pappiatendente.com.br"

# =============================================
# WEBHOOK META (verificaГ§ГЈo inicial)
# =============================================
WEBHOOK_VERIFY_TOKEN="token_secreto_que_voce_escolhe"

# =============================================
# WHATSAPP CLOUD API (fallback single-tenant)
# Em multi-tenant, os dados ficam no banco (tabela tenants).
# =============================================
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WABA_ID=""

# =============================================
# CARDГЃPIO WEB
# =============================================
CARDAPIOWEB_BASE_URL="https://integracao.cardapioweb.com"
CARDAPIOWEB_API_KEY=""
CARDAPIOWEB_PARTNER_KEY=""
CARDAPIOWEB_STORE_ID=""

# =============================================
# GOOGLE MAPS (cГЎlculo de distГўncia/taxa)
# =============================================
GOOGLE_MAPS_API_KEY=""

# =============================================
# GEMINI (IA вЂ” obrigatГіrio para o bot funcionar)
# =============================================
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# OPENAI (fallback quando Gemini falha вЂ” opcional)
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"

# GROQ (fallback Llama вЂ” opcional, tier gratuito generoso)
# GROQ_API_KEY=""
# GROQ_MODEL="llama-3.1-8b-instant"

# =============================================
# GOOGLE OAUTH (para login no painel via Google)
# =============================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =============================================
# INSTAGRAM / FACEBOOK MESSENGER (opcional)
# =============================================
INSTAGRAM_PAGE_ID=""
FACEBOOK_PAGE_ID=""
FACEBOOK_PAGE_TOKEN=""

# =============================================
# COORDENADAS DA LOJA (usado para cГЎlculo de taxa)
# =============================================
STORE_LAT=-22.9060
STORE_LNG=-47.0616

# =============================================
# BANCO INTER (PIX вЂ” opcional)
# =============================================
# INTER_CLIENT_ID=""
# INTER_CLIENT_SECRET=""
# INTER_CHAVE_PIX=""
# INTER_CONTA_CORRENTE=""
# INTER_CERT_PATH="./certificados/inter.crt"
# INTER_KEY_PATH="./certificados/inter.key"

# =============================================
# HORГЃRIO DE FUNCIONAMENTO
# =============================================
# SKIP_HOURS_CHECK=true вЂ” desativa a trava de horГЎrio (para testes)
# SKIP_HOURS_CHECK=

# CLOSED_AS_LEAD=true вЂ” quando fechado, aceita pedidos como "lead" (entra em contato ao abrir)
# CLOSED_AS_LEAD=

# =============================================
# ATENDIMENTO HГЌBRIDO (humano + robГґ)
# =============================================
# CONVERSATION_HANDOFF_TIMEOUT_MIN=15 вЂ” devolve ao robГґ apГіs 15 min de inatividade (0 = desativado)
# CONVERSATION_HANDOFF_TIMEOUT_MIN=

# =============================================
# RATE LIMIT (mensagens/min вЂ” evitar bloqueios em conversas ativas)
# =============================================
# RATE_LIMIT_WEBHOOK_MAX=60
# RATE_LIMIT_GEMINI_MAX=15
# RATE_LIMIT_ORDER_MAX=5

# =============================================
# SERVIDOR E PROCESSOS
# =============================================
PORT=10000
NODE_ENV=development

# APP_ENV: prod | staging | dev | local вЂ” isolamento de sessГЈo Baileys entre ambientes (evita 440)
# Se nГЈo definido, usa NODE_ENV (prodв†’prod, developmentв†’dev, outroв†’local)
APP_ENV=local

# OBRIGATГ“RIO em produГ§ГЈo: Baileys exige 1 Гєnico processo
WEB_CONCURRENCY=1

# SeparaГ§ГЈo de processos:
# - start:web (bootstrap/http.js): RUN_BAILEYS=false, RUN_JOBS=true
# - start:baileys (bootstrap/baileys.js): RUN_BAILEYS=true, RUN_JOBS=false
# - index.js (monГіlito): RUN_JOBS=true, RUN_BAILEYS=true
RUN_JOBS=true
RUN_BAILEYS=true
BAILEYS_ENABLED=true

# Baileys: lock e proteГ§ГЈo 440 (ver docs/BAILEYS_440.md)
BAILEYS_LOCK_TTL_MS=60000
BAILEYS_PROCESS_NAME=pappi-baileys
BAILEYS_HOSTNAME=
# BAILEYS_CLEAR_AUTH_ON_440=true вЂ” limpa auth ao 440 (exige novo QR). Use com critГ©rio.
# BAILEYS_CLEAR_AUTH_ON_440=

# =============================================
# OBSERVABILIDADE (opcional)
# =============================================
# HEALTHCHECK_TOKEN=token_secreto
# REDIS_URL=redis://localhost:6379
# SENTRY_DSN=

# =============================================
# LOGS (debug | info | warn | error)
# =============================================
LOG_LEVEL=debug
