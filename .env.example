# =============================================
# BANCO DE DADOS INTERNO (Supabase / Neon / Railway)
# =============================================
DATABASE_URL="postgresql://usuario:senha@host:5432/nomebanco?sslmode=require"
DIRECT_URL="postgresql://usuario:senha@host:5432/nomebanco?sslmode=require"

# =============================================
# SEGURANÇA
# =============================================
ATTENDANT_API_KEY="chave_secreta_atendente"
ADMIN_API_KEY="chave_secreta_admin"

# Auth corporativa (Supabase) — painel fechado
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
USE_STAFF_AUTH=true
ALLOW_API_KEY_FALLBACK=false
APP_URL="https://app.pappiatendente.com.br"
API_URL="https://api.pappiatendente.com.br"
CORS_ORIGIN="https://app.pappiatendente.com.br"

# =============================================
# WEBHOOK META (verificação inicial)
# =============================================
WEBHOOK_VERIFY_TOKEN="token_secreto_que_voce_escolhe"

# =============================================
# WHATSAPP CLOUD API (fallback single-tenant)
# Em multi-tenant, os dados ficam no banco (tabela tenants).
# =============================================
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WABA_ID=""

# =============================================
# CARDÁPIO WEB
# =============================================
CARDAPIOWEB_BASE_URL="https://integracao.cardapioweb.com"
CARDAPIOWEB_API_KEY=""
CARDAPIOWEB_PARTNER_KEY=""
CARDAPIOWEB_STORE_ID=""

# =============================================
# GOOGLE MAPS (cálculo de distância/taxa)
# =============================================
GOOGLE_MAPS_API_KEY=""

# =============================================
# GEMINI (IA — obrigatório para o bot funcionar)
# =============================================
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# OPENAI (fallback quando Gemini falha — opcional)
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"

# GROQ (fallback Llama — opcional, tier gratuito generoso)
# GROQ_API_KEY=""
# GROQ_MODEL="llama-3.1-8b-instant"

# =============================================
# GOOGLE OAUTH (para login no painel via Google)
# =============================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =============================================
# INSTAGRAM / FACEBOOK MESSENGER (opcional)
# =============================================
INSTAGRAM_PAGE_ID=""
FACEBOOK_PAGE_ID=""
FACEBOOK_PAGE_TOKEN=""

# =============================================
# COORDENADAS DA LOJA (usado para cálculo de taxa)
# =============================================
STORE_LAT=-22.9060
STORE_LNG=-47.0616

# =============================================
# BANCO INTER (PIX — opcional)
# =============================================
# INTER_CLIENT_ID=""
# INTER_CLIENT_SECRET=""
# INTER_CHAVE_PIX=""
# INTER_CONTA_CORRENTE=""
# INTER_CERT_PATH="./certificados/inter.crt"
# INTER_KEY_PATH="./certificados/inter.key"

# =============================================
# HORÁRIO DE FUNCIONAMENTO
# =============================================
# SKIP_HOURS_CHECK=true — desativa a trava de horário (para testes)
# SKIP_HOURS_CHECK=

# CLOSED_AS_LEAD=true — quando fechado, aceita pedidos como "lead" (entra em contato ao abrir)
# CLOSED_AS_LEAD=

# =============================================
# ATENDIMENTO HÍBRIDO (humano + robô)
# =============================================
# CONVERSATION_HANDOFF_TIMEOUT_MIN=15 — devolve ao robô após 15 min de inatividade (0 = desativado)
# CONVERSATION_HANDOFF_TIMEOUT_MIN=

# =============================================
# RATE LIMIT (mensagens/min — evitar bloqueios em conversas ativas)
# =============================================
# RATE_LIMIT_WEBHOOK_MAX=60
# RATE_LIMIT_GEMINI_MAX=15
# RATE_LIMIT_ORDER_MAX=5

# =============================================
# SERVIDOR
# =============================================
PORT=10000
NODE_ENV=production

# =============================================
# LOGS (debug | info | warn | error)
# =============================================
LOG_LEVEL=info
