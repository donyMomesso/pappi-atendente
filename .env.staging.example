# =============================================
# PAPPI ATENDENTE — HOMOLOGAÇÃO (STAGING)
# Ambiente de testes antes de produção.
# Use banco SEPARADO de produção.
# =============================================

NODE_ENV=staging
PORT=10001

# OBRIGATÓRIO: staging ≠ prod — sessões Baileys isoladas (evita 440)
APP_ENV=staging

WEB_CONCURRENCY=1
RUN_JOBS=true
RUN_BAILEYS=true
BAILEYS_ENABLED=true

# Banco de HOMOLOGAÇÃO (diferente de produção!)
DATABASE_URL="postgresql://user:pass@host:5432/pappi_staging?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/pappi_staging?sslmode=require"

# Chaves específicas de homologação
ATTENDANT_API_KEY="chave-staging-atendente"
ADMIN_API_KEY="chave-staging-admin"
WEBHOOK_VERIFY_TOKEN="token-staging-webhook"

# Supabase staging (projeto separado)
SUPABASE_URL="https://xxx-staging.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET="pappi-media"
USE_STAFF_AUTH=true
ALLOW_API_KEY_FALLBACK=true

# URLs staging
APP_URL="https://staging.pappiatendente.com.br"
API_URL="https://api-staging.pappiatendente.com.br"
CORS_ORIGIN="https://staging.pappiatendente.com.br,http://localhost:3000"

# Demais variáveis: espelhe produção com valores de teste
WHATSAPP_TOKEN=""
CARDAPIOWEB_API_KEY=""
CARDAPIOWEB_PARTNER_KEY=""
CARDAPIOWEB_STORE_ID=""
GEMINI_API_KEY=""
GOOGLE_MAPS_API_KEY=""
STORE_LAT=-22.9060
STORE_LNG=-47.0616

LOG_LEVEL=debug
SKIP_HOURS_CHECK=true
META_APP_SECRET=
REDIS_URL=redis://localhost:6379
METRICS_TOKEN=
ENTERPRISE_MODE=true


# Runtime deste processo: monolith | web | baileys | jobs
APP_RUNTIME=monolith
# embedded = monólito; dedicated = QR em processo separado
BAILEYS_INSTANCE_MODE=embedded
