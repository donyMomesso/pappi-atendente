generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

model Tenant {
  id              String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  name            String
  active          Boolean      @default(true)
  waToken         String
  waPhoneNumberId String       @unique
  waWabaId        String?
  cwBaseUrl       String       @default("https://integracao.cardapioweb.com")
  cwApiKey        String
  cwPartnerKey    String
  cwStoreId       String?
  city            String?
  webhookToken    String?
  createdAt       DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  customers       Customer[]
  orders          Order[]
  staffUsers      StaffUser[]

  @@map("tenants")
  @@schema("public")
}

model StaffUser {
  id            String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  authUserId    String    @unique
  tenantId      String?
  email         String
  name          String
  role          String    // admin | manager | attendant
  active        Boolean   @default(true)
  invitedBy     String?
  lastLoginAt   DateTime? @db.Timestamptz(6)
  canViewOrders Boolean   @default(true)
  canSendMessages Boolean @default(true)
  canManageCoupons Boolean @default(false)
  canManageSettings Boolean @default(false)
  canManageUsers Boolean   @default(false)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([email], map: "idx_staff_users_email")
  @@index([authUserId], map: "idx_staff_users_auth_user_id")
  @@index([tenantId], map: "idx_staff_users_tenant")
  @@index([role], map: "idx_staff_users_role")
  @@index([active], map: "idx_staff_users_active")
  @@index([tenantId, active], map: "idx_staff_users_tenant_active")
  @@map("staff_users")
  @@schema("public")
}

model AuditLog {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId     String?
  userId       String?
  action       String
  resourceType String?
  resourceId   String?
  metadata     String?  // JSON
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  @@index([tenantId, createdAt], map: "idx_audit_logs_tenant_created")
  @@index([userId, createdAt], map: "idx_audit_logs_user_created")
  @@index([action, createdAt], map: "idx_audit_logs_action_created")
  @@map("audit_logs")
  @@schema("public")
}

model Customer {
  id               String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId         String
  phone            String
  name             String?
  lastAddress      String?
  lastStreet       String?
  lastNumber       String?
  lastNeighborhood String?
  lastComplement   String?
  lastCity         String?
  lastLat          Float?
  lastLng          Float?
  handoff          Boolean   @default(false)
  handoffAt        DateTime? @db.Timestamptz(6)
  visitCount       Int       @default(0)
  lastInteraction  DateTime  @default(now()) @db.Timestamptz(6)
  lastOrderSummary String?
  preferredPayment String?
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  queuedAt         DateTime? @db.Timestamptz(6)
  claimedBy        String?
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages         Message[]
  orders           Order[]

  @@unique([tenantId, phone], name: "tenantId_phone")
  @@index([tenantId], map: "idx_customers_tenantid")
  @@map("customers")
  @@schema("public")
}

model Order {
  id                String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId          String
  customerId        String
  idempotencyKey    String
  status            String           @default("waiting_confirmation")
  total             Float
  deliveryFee       Float            @default(0)
  discount          Float            @default(0)
  totalValidated    Boolean          @default(false)
  totalExpected     Float?
  fulfillment       String
  paymentMethodId   String?
  paymentMethodName String?
  itemsSnapshot     String
  addressSnapshot   String?
  cwOrderId         String?          @unique
  cwPayload         String?
  cwResponse        String?
  createdAt         DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  // ── Monitoramento de atraso (CardápioWeb) ──
  cardapiowebStatus           String?
  statusChangedAt             DateTime? @db.Timestamptz(6)
  timeInCurrentStatusMinutes  Int?
  dailyAvgProdToOutMinutes    Float?
  dailyAvgOutToDoneMinutes    Float?
  estimatedRemainingMin       Int?
  estimatedRemainingMax       Int?
  weatherDelayFactor          Float?
  delayAlertSentAt            DateTime? @db.Timestamptz(6)
  secondDelayAlertSentAt      DateTime? @db.Timestamptz(6)
  thirdDelayAlertSentAt       DateTime? @db.Timestamptz(6)
  attendantAlertSentAt        DateTime? @db.Timestamptz(6)
  watchedByAttendant          String?
  deliveryRiskLevel           String?
  compensationEligible        Boolean   @default(false)
  compensationReason          String?
  compensationType            String?
  couponCode                  String?
  couponGeneratedAt           DateTime? @db.Timestamptz(6)
  couponSentAt                DateTime? @db.Timestamptz(6)
  statusLogs        OrderStatusLog[]
  customer          Customer         @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenantId, idempotencyKey], name: "tenantId_idempotencyKey")
  @@index([customerId], map: "idx_orders_customerid")
  @@index([tenantId, status], map: "idx_orders_tenantid_status")
  @@index([tenantId, cardapiowebStatus], map: "idx_orders_tenant_cw_status")
  @@map("orders")
  @@schema("public")
}

model OrderStatusLog {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId   String
  status    String
  source    String   @default("system")
  note      String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([orderId], map: "idx_order_status_logs_orderid")
  @@map("order_status_logs")
  @@schema("public")
}

model Message {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  customerId  String
  role        String
  text        String
  sender      String?
  mediaUrl    String?
  mediaType   String?  @default("text")
  waMessageId String?
  status      String?  @default("sent")
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([customerId, createdAt], map: "messages_customer_created")
  @@index([waMessageId], map: "idx_messages_wa_message_id")
  @@map("messages")
  @@schema("public")
}

model Config {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("configs")
  @@schema("public")
}

model RetentionCampaign {
  id           String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId     String
  name         String
  message      String
  delayHours   Int             @default(20)
  monthlyLimit Int             @default(100)
  aiFilter     Boolean         @default(true)
  active       Boolean         @default(false)
  createdAt    DateTime        @default(now()) @db.Timestamptz(6)
  sends        RetentionSend[]

  @@index([tenantId, active], map: "idx_ret_campaigns_tenant_active")
  @@map("retention_campaigns")
  @@schema("public")
}

model RetentionSend {
  id           String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  campaignId   String
  customerId   String
  phone        String
  customerName String?
  aiScore      String?
  sentAt       DateTime          @default(now()) @db.Timestamptz(6)
  campaign     RetentionCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([campaignId, sentAt], map: "idx_ret_sends_campaign_sent")
  @@index([customerId, sentAt], map: "idx_ret_sends_customer_sent")
  @@map("retention_sends")
  @@schema("public")
}

// ── Auth (mínimo necessário para o Prisma não reclamar) ───────

model users {
  id              String            @id @db.Uuid
  email           String?           @db.VarChar(255)
  created_at      DateTime?         @db.Timestamptz(6)
  updated_at      DateTime?         @db.Timestamptz(6)
  is_anonymous    Boolean           @default(false)
  deleted_at      DateTime?         @db.Timestamptz(6)
  identities      identities[]
  mfa_factors     mfa_factors[]
  one_time_tokens one_time_tokens[]
  sessions        sessions[]

  @@schema("auth")
}

model identities {
  provider_id   String
  user_id       String    @db.Uuid
  identity_data Json
  provider      String
  created_at    DateTime? @db.Timestamptz(6)
  updated_at    DateTime? @db.Timestamptz(6)
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  users         users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider_id, provider], map: "identities_provider_id_provider_unique")
  @@schema("auth")
}

model sessions {
  id             String           @id @db.Uuid
  user_id        String           @db.Uuid
  created_at     DateTime?        @db.Timestamptz(6)
  updated_at     DateTime?        @db.Timestamptz(6)
  not_after      DateTime?        @db.Timestamptz(6)
  mfa_amr_claims mfa_amr_claims[]
  refresh_tokens refresh_tokens[]
  users          users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("auth")
}

model mfa_amr_claims {
  session_id            String   @db.Uuid
  created_at            DateTime @db.Timestamptz(6)
  updated_at            DateTime @db.Timestamptz(6)
  authentication_method String
  id                    String   @id(map: "amr_id_pk") @db.Uuid
  sessions              sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([session_id, authentication_method], map: "mfa_amr_claims_session_id_authentication_method_pkey")
  @@schema("auth")
}

model mfa_factors {
  id             String           @id @db.Uuid
  user_id        String           @db.Uuid
  factor_type    factor_type
  status         factor_status
  created_at     DateTime         @db.Timestamptz(6)
  updated_at     DateTime         @db.Timestamptz(6)
  mfa_challenges mfa_challenges[]
  users          users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("auth")
}

model mfa_challenges {
  id          String      @id @db.Uuid
  factor_id   String      @db.Uuid
  created_at  DateTime    @db.Timestamptz(6)
  ip_address  String      @db.Inet
  mfa_factors mfa_factors @relation(fields: [factor_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "mfa_challenges_auth_factor_id_fkey")

  @@schema("auth")
}

model refresh_tokens {
  id         BigInt    @id @default(autoincrement())
  token      String?   @unique(map: "refresh_tokens_token_unique") @db.VarChar(255)
  user_id    String?   @db.VarChar(255)
  revoked    Boolean?
  created_at DateTime? @db.Timestamptz(6)
  updated_at DateTime? @db.Timestamptz(6)
  session_id String?   @db.Uuid
  sessions   sessions? @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("auth")
}

model one_time_tokens {
  id         String              @id @db.Uuid
  user_id    String              @db.Uuid
  token_type one_time_token_type
  token_hash String
  relates_to String
  created_at DateTime            @default(now()) @db.Timestamp(6)
  updated_at DateTime            @default(now()) @db.Timestamp(6)
  users      users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, token_type])
  @@schema("auth")
}

enum aal_level {
  aal1
  aal2
  aal3
  @@schema("auth")
}

enum factor_status {
  unverified
  verified
  @@schema("auth")
}

enum factor_type {
  totp
  webauthn
  phone
  @@schema("auth")
}

enum one_time_token_type {
  confirmation_token
  reauthentication_token
  recovery_token
  email_change_token_new
  email_change_token_current
  phone_change_token
  @@schema("auth")
}
