  cached_discovery      Json?
  discovery_cached_at   DateTime? @db.Timestamptz(6)
  authorization_url     String?
  token_url             String?
  userinfo_url          String?
  jwks_uri              String?
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime  @default(now()) @db.Timestamptz(6)

  @@index([created_at])
  @@index([enabled])
  @@index([identifier])
  @@index([provider_type])
  @@schema("auth")
}

