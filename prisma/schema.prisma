  empresa_id                                                     String                 @db.Uuid
  nome_produto                                                   String
  categoria_produto                                              String                 @default("Outros")
  unidade_medida                                                 unidade_medida         @default(unidade)
  custo_medio                                                    Decimal?               @db.Decimal(12, 4)
  ultimo_custo                                                   Decimal?               @db.Decimal(12, 4)
  ean                                                            String?
  sku                                                            String?
  fornecedor_preferencial_id                                     String?                @db.Uuid
  estoque_minimo                                                 Decimal                @default(0) @db.Decimal(12, 3)
  estoque_atual                                                  Decimal                @default(0) @db.Decimal(12, 3)
  ativo                                                          Boolean                @default(true)
  created_at                                                     DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at                                                     DateTime?              @default(now()) @db.Timestamptz(6)
  unidade_compra                                                 String?
  pedidos_compra_itens                                           pedidos_compra_itens[]
  empresas                                                       empresas               @relation(fields: [empresa_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  fornecedores                                                   fornecedores?          @relation(fields: [fornecedor_preferencial_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recebimento_itens_recebimento_itens_match_produto_idToprodutos recebimento_itens[]    @relation("recebimento_itens_match_produto_idToprodutos")
  recebimento_itens_recebimento_itens_produto_idToprodutos       recebimento_itens[]    @relation("recebimento_itens_produto_idToprodutos")

  @@index([empresa_id], map: "idx_produtos_empresa")
  @@index([nome_produto(ops: raw("gin_trgm_ops"))], map: "idx_produtos_nome_trgm", type: Gin)
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model profiles {
  id              String            @id @db.Uuid
  nome            String?
  email           String?
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  company_members company_members[]
  company_users   company_users[]
  users           users             @relation(fields: [id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model recebimento_itens {
  id                                                    String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  recebimento_id                                        String          @db.Uuid
  produto_id                                            String?         @db.Uuid
  descricao_nota                                        String
  quantidade_nota                                       Decimal         @default(0) @db.Decimal(12, 3)
  unidade_nota                                          String?
  unidade_normalizada                                   unidade_medida?
  valor_unitario_nota                                   Decimal         @default(0) @db.Decimal(12, 4)
  valor_total_nota                                      Decimal         @default(0) @db.Decimal(12, 2)
  codigo_fornecedor                                     String?
  ncm                                                   String?
  ean                                                   String?
  match_produto_id                                      String?         @db.Uuid
  match_confianca                                       Decimal?        @db.Decimal(4, 3)
  match_metodo                                          String?
  match_status                                          match_status    @default(pendente)
  tem_divergencia                                       Boolean         @default(false)
  divergencias                                          Json?
  created_at                                            DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at                                            DateTime?       @default(now()) @db.Timestamptz(6)
  produtos_recebimento_itens_match_produto_idToprodutos produtos?       @relation("recebimento_itens_match_produto_idToprodutos", fields: [match_produto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  produtos_recebimento_itens_produto_idToprodutos       produtos?       @relation("recebimento_itens_produto_idToprodutos", fields: [produto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recebimentos                                          recebimentos    @relation(fields: [recebimento_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([match_produto_id], map: "idx_receb_itens_produto")
  @@index([recebimento_id], map: "idx_receb_itens_recebimento")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model recebimentos {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  empresa_id        String              @db.Uuid
  pedido_compra_id  String?             @db.Uuid
  fornecedor_id     String?             @db.Uuid
  numero_nota       String?
  serie_nota        String?
  chave_acesso      String?
  data_emissao      DateTime?           @db.Date
  valor_total_nota  Decimal?            @db.Decimal(12, 2)
  arquivo_url       String?
  xml_url           String?
  json_extraido     Json?
  status            status_recebimento  @default(pendente)
  observacao        String?
  criado_por        String?             @db.Uuid
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  contas_pagar      contas_pagar[]
  recebimento_itens recebimento_itens[]
  usuarios          usuarios?           @relation(fields: [criado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  empresas          empresas            @relation(fields: [empresa_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  fornecedores      fornecedores?       @relation(fields: [fornecedor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pedidos_compra    pedidos_compra?     @relation(fields: [pedido_compra_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([empresa_id], map: "idx_recebimentos_empresa")
  @@index([empresa_id, status], map: "idx_recebimentos_status")
  @@schema("public")
}

model usuarios {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email            String             @unique
  nome             String?
  avatar_url       String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  empresa_usuarios empresa_usuarios[]
  pedidos_compra   pedidos_compra[]
  recebimentos     recebimentos[]

  @@index([email], map: "idx_usuarios_email")
  @@schema("public")
}

