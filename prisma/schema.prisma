generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

// ── Tenant (loja) ─────────────────────────────────────────────
model Tenant {
  id              String     @id @default(uuid())
  name            String
  active          Boolean    @default(true)

  // WhatsApp Cloud API
  waToken         String
  waPhoneNumberId String     @unique
  waWabaId        String?

  // CardápioWeb (banco externo de cardápio)
  cwBaseUrl       String     @default("https://integracao.cardapioweb.com")
  cwApiKey        String
  cwPartnerKey    String
  cwStoreId       String?

  // Config da loja
  city            String?
  webhookToken    String?    // verify_token específico do tenant (opcional)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  customers       Customer[]
  orders          Order[]

  @@map("tenants")
  @@schema("public")
}

// ── Customer (cliente por tenant) ────────────────────────────
model Customer {
  id               String    @id @default(uuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id])

  phone            String    // E.164 sem "+": 5511987654321
  name             String?

  // Endereço mais recente
  lastAddress      String?
  lastStreet       String?
  lastNumber       String?
  lastNeighborhood String?
  lastComplement   String?
  lastCity         String?
  lastLat          Float?
  lastLng          Float?

  // Estado do bot
  handoff          Boolean   @default(false)
  handoffAt        DateTime?

  // Fila de atendimento
  queuedAt         DateTime? // quando entrou na fila (handoff ativado)
  claimedBy        String?   // nome do atendente que assumiu (null = na fila)

  // Histórico
  visitCount       Int       @default(0)
  lastInteraction  DateTime  @default(now())
  lastOrderSummary String?
  preferredPayment String?

  createdAt        DateTime  @default(now())
  orders           Order[]
  messages         Message[]

  @@unique([tenantId, phone], name: "tenantId_phone")
  @@map("customers")
  @@schema("public")
}

// ── Order (pedido) ────────────────────────────────────────────
model Order {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id])

  // Req 3 — Idempotência
  idempotencyKey   String

  // Status
  status           String   @default("waiting_confirmation")

  // Financeiro
  total            Float
  deliveryFee      Float    @default(0)
  discount         Float    @default(0)
  totalValidated   Boolean  @default(false)
  totalExpected    Float?

  // Fulfillment
  fulfillment      String   // "delivery" | "takeout"

  // Pagamento
  paymentMethodId  String?
  paymentMethodName String?

  // Req 5 — Snapshot completo dos itens
  itemsSnapshot    String   // JSON dos itens no momento do pedido
  addressSnapshot  String?  // JSON do endereço no momento do pedido

  // CardápioWeb
  cwOrderId        String?  @unique
  cwPayload        String?  // JSON enviado ao CW
  cwResponse       String?  // JSON recebido do CW

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  statusLogs       OrderStatusLog[]

  @@unique([tenantId, idempotencyKey], name: "tenantId_idempotencyKey")
  @@index([tenantId, status])
  @@index([customerId])
  @@map("orders")
  @@schema("public")
}

// ── OrderStatusLog (auditoria de status) ─────────────────────
model OrderStatusLog {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  status    String
  source    String   @default("system") // bot | human | webhook | system
  note      String?
  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_status_logs")
  @@schema("public")
}

// ── Message (histórico de conversa) ──────────────────────────
model Message {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  role       String   // "customer" | "attendant" | "bot"
  text       String
  sender     String?  // nome do atendente (quando role=attendant)
  
  // Mídia
  mediaUrl   String?
  mediaType  String   @default("text") // text | image | audio | video | document
  
  // Status da Meta
  waMessageId String? @unique // ID retornado pela Meta
  status      String? // sent | delivered | read | failed

  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
  @@map("messages")
  @@schema("public")
}

// ── Config (chave-valor global) ───────────────────────────────
model Config {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("configs")
  @@schema("public")
}

// ── RetentionCampaign (campanha de retenção) ──────────────────
model RetentionCampaign {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  message      String   // Texto da mensagem; {nome} é substituído
  delayHours   Int      @default(20)  // Enviar X horas após última interação
  monthlyLimit Int      @default(100) // Limite de envios por mês
  aiFilter     Boolean  @default(true) // Usar IA para filtrar candidatos
  active       Boolean  @default(false)
  createdAt    DateTime @default(now())

  sends        RetentionSend[]

  @@index([tenantId, active])
  @@map("retention_campaigns")
  @@schema("public")
}

// ── RetentionSend (log de envios de retenção) ─────────────────
model RetentionSend {
  id           String            @id @default(uuid())
  campaignId   String
  campaign     RetentionCampaign @relation(fields: [campaignId], references: [id])
  customerId   String
  phone        String
  customerName String?
  aiScore      String?           // "sim" | "talvez" | "nao" com motivo
  sentAt       DateTime          @default(now())

  @@index([campaignId, sentAt])
  @@index([customerId, sentAt])
  @@map("retention_sends")
  @@schema("public")
}
